{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:rac:ebrc:proof:v1",
  "title": "EBRC proof DAG v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "proof_id",
    "graph_digest_sha256",
    "requested_claim_digest_sha256",
    "root_step_id",
    "steps",
    "declared_missing_obligations"
  ],
  "properties": {
    "schema": {"const": "rac-ebrc-proof-v1"},
    "proof_id": {"$ref": "#/$defs/id"},
    "graph_digest_sha256": {"$ref": "#/$defs/sha256"},
    "requested_claim_digest_sha256": {"$ref": "#/$defs/sha256"},
    "root_step_id": {
      "oneOf": [
        {"$ref": "#/$defs/id"},
        {"type": "null"}
      ]
    },
    "steps": {
      "type": "array",
      "items": {"$ref": "#/$defs/step"}
    },
    "declared_missing_obligations": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/id"}
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:@-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "rule",
        "premises",
        "evidence_refs",
        "conclusion"
      ],
      "properties": {
        "step_id": {"$ref": "#/$defs/id"},
        "rule": {
          "enum": [
            "RAW",
            "MUST",
            "COLLISION",
            "OBSERVER_INEQUALITY",
            "NONFACTOR",
            "PROSPECTIVE",
            "CONTEXT_TRANSPORT"
          ]
        },
        "premises": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/id"}
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/id"}
        },
        "conclusion": {"$ref": "#/$defs/claim"}
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "claim_id",
        "predicate",
        "quantifier",
        "scope",
        "evidence_grade",
        "subject"
      ],
      "properties": {
        "schema": {"const": "rac-ebrc-claim-v1"},
        "claim_id": {"$ref": "#/$defs/id"},
        "predicate": {
          "enum": [
            "MAY_OUTCOME",
            "MUST_OUTCOME",
            "REPORT_COLLISION",
            "OBSERVER_INEQUALITY",
            "NONFACTORING"
          ]
        },
        "quantifier": {"enum": ["AT", "EXISTS", "FORALL"]},
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scope_digest_sha256",
            "report_authority",
            "report_relation_id",
            "frontier_id",
            "context_id",
            "suffix_id",
            "observer_id"
          ],
          "properties": {
            "scope_digest_sha256": {"$ref": "#/$defs/sha256"},
            "report_authority": {
              "enum": [
                "OPERATIONAL_OBSERVATION",
                "IMPLEMENTATION_SPECIFIED",
                "EXTERNAL_SPECIFIED"
              ]
            },
            "report_relation_id": {"$ref": "#/$defs/id"},
            "frontier_id": {"$ref": "#/$defs/id"},
            "context_id": {"$ref": "#/$defs/id"},
            "suffix_id": {"$ref": "#/$defs/id"},
            "observer_id": {"$ref": "#/$defs/id"}
          }
        },
        "evidence_grade": {
          "enum": [
            "RETROSPECTIVE_EXACT",
            "OUTCOME_FREE_PRECOMMITTED",
            "TRANSPORTED"
          ]
        },
        "subject": {"type": "object", "minProperties": 1}
      }
    }
  }
}
