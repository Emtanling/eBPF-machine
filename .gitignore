__pycache__/
*.py[cod]
.DS_Store
._*

# Local backups and agent work files.
*.bak_*
/.bak_*/
/.codex-backup-*/
/.codex_backups/
/.revision-backups/
/.revision-incoming/
/reviews/
/.interpreter_suite.lock

# Rebuildable native and generated source artifacts.
/build/
/src/vmlinux.h
/circuits/*.wmc
/circuits/boundary/
/circuits/generated/

# Keep only the report-bound evidence bundle in version control.
/results/*
!/results/interpreter/
/results/interpreter/*
!/results/interpreter/interpreter-final-20260711-02/
!/results/linux_r/
/results/linux_r/*
!/results/linux_r/linux-r-v1/
!/results/linux_r/linux-r-v1/**

# Keep the final paper PDF, not LaTeX intermediates.
/output/pdf/*
!/output/pdf/PAPER_REPORT.pdf
!/output/pdf/PAPER_REPORT_ZH.pdf
/*.aux
/*.log
/*.out
/PAPER_REPORT*.pdf
/PAPER_REPORT_arxiv.tar.gz

# Keep only the frozen stock-Linux proof and its minimal verifier.
/residuality-auditor/*
!/residuality-auditor/LICENSE
!/residuality-auditor/README.md
!/residuality-auditor/tools/
!/residuality-auditor/tools/__init__.py
!/residuality-auditor/tools/proof/
!/residuality-auditor/tools/proof/__init__.py
!/residuality-auditor/tools/proof/check_frozen_bundle.py
!/residuality-auditor/stock-linux-r-proof/
!/residuality-auditor/stock-linux-r-proof/**

# Historical/internal documents retained locally only.
/EDITORIAL_DECISION.md
/PAPER_DRAFT.md
/PEER_REVIEW.md
/PAPER_*_REPORT.md
/PAPER_*_REPORT.tex
/*_REVISION_*.md
/*_RE_REVIEW_*.md
/REVISION_RESPONSE_*.md
/RE_REVIEW_*.md
